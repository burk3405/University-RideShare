# Auth0 Configuration
# Create an application at https://manage.auth0.com/
# Application Type: Single Page Application
#
# Required Callback URLs (in Auth0 Dashboard):
#   Allowed Callback URLs:  http://localhost:3000/dashboard
#   Allowed Logout URLs:    http://localhost:3000/login
#   Allowed Web Origins:    http://localhost:3000
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=your-client-id
# Optional – required only if calling a protected API
# VITE_AUTH0_AUDIENCE=https://your-api-identifier

# Google Maps Configuration
# Enable the following APIs in Google Cloud Console:
#   - Maps JavaScript API
#   - Directions API
#   - Places API (optional)
# Restrict the API key to HTTP referrers: http://localhost:3000/*
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
